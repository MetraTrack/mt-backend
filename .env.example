# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=MetraTrack-Backend
PORT=3000
NODE_ENV=development
# Comma-separated list of allowed origins (production only)
CORS_ORIGINS=https://app.metratrack.com

# ─────────────────────────────────────────────────────────────────────────────
# Swagger (production only)
# ─────────────────────────────────────────────────────────────────────────────
SWAGGER_SERVER_URL=http://backend:3000

# ─────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=metratrack

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-jwt-secret-in-production
JWT_EXPIRES_IN=3600s
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────────────────
# S3 / MinIO object storage
# ─────────────────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin12345
S3_BUCKET=metratrack
S3_FORCE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────────────────────
# HTTP client (for external service calls)
# ─────────────────────────────────────────────────────────────────────────────
HTTP_TIMEOUT_MS=10000
HTTP_RETRIES=3
HTTP_RETRY_DELAY_MS=1000