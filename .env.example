# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=MetraTrack-Backend
PORT=3000
NODE_ENV=development
# Comma-separated list of allowed origins (production only)
CORS_ORIGINS=https://app.metratrack.com

# ─────────────────────────────────────────────────────────────────────────────
# Swagger (production only)
# ─────────────────────────────────────────────────────────────────────────────
SWAGGER_SERVER_URL=http://backend:3000

# ─────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=metratrack

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# API access
# ─────────────────────────────────────────────────────────────────────────────
# Shared secret used by all consumers (Telegram bot, admin tools) via X-API-KEY header
API_KEY=change-this-api-key-in-production

# ─────────────────────────────────────────────────────────────────────────────
# Admin users
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of Telegram user IDs that have admin access
TG_ADMIN_IDS=123456789,987654321

# ─────────────────────────────────────────────────────────────────────────────
# S3 / MinIO object storage
# ─────────────────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin12345
S3_BUCKET=metratrack
S3_FORCE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────────────────────
# HTTP client (for external service calls)
# ─────────────────────────────────────────────────────────────────────────────
HTTP_TIMEOUT_MS=10000
HTTP_RETRIES=3
HTTP_RETRY_DELAY_MS=1000

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Vision-capable model for image analysis and text generation
OPENAI_MODEL=gpt-4o
OPENAI_MAX_OUTPUT_TOKENS=2048
# SDK-level retries for network errors, 429, 5xx (default: 2)
OPENAI_RETRIES=2
# Request timeout in ms (default: 60000)
OPENAI_TIMEOUT_MS=60000
# In-process sliding-window rate limit: max requests per 60s
OPENAI_RATE_LIMIT_RPM=60

# ─────────────────────────────────────────────────────────────────────────────
# Food photo analysis
# ─────────────────────────────────────────────────────────────────────────────
# Max accepted upload size in bytes (default: 10 MB)
FOOD_PHOTO_MAX_SIZE_BYTES=10485760
# Max width after resize (larger images are scaled down, default: 1280 px)
FOOD_PHOTO_MAX_WIDTH=1280
# JPEG quality for processed photos sent to OpenAI and stored in S3 (default: 85)
FOOD_PHOTO_JPEG_QUALITY=85

# ─────────────────────────────────────────────────────────────────────────────
# Bot backend callback
# ─────────────────────────────────────────────────────────────────────────────
# Base URL of the bot backend (e.g. http://localhost:4000)
BOT_HOST=http://localhost:4000
# Path the bot exposes to receive analysis results
BOT_CALLBACK_ANALYSIS_PATH=/internal/food-analysis-result
# Callbacks use the same shared API_KEY (X-API-KEY header)